# Database
DATABASE_URL="postgresql://nombaos:nombaos_dev_password@localhost:5432/nombaos"

# JWT
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Clerk (https://clerk.com)
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# Nomba API
NOMBA_BASE_URL="https://api.nomba.com/v1"
NOMBA_CLIENT_ID="your-nomba-client-id"
NOMBA_CLIENT_SECRET="your-nomba-client-secret"
NOMBA_ACCOUNT_ID="your-nomba-account-id"

# Google Gemini (https://aistudio.google.com/apikey)
# Powers the AI chat agent (gemini-2.0-flash) and vector memory embeddings (gemini-embedding-001).
GEMINI_API_KEY="AIza..."

# Redis (docker-compose spins this up locally)
REDIS_URL="redis://localhost:6379"

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# Sentry (https://sentry.io — create a NestJS/Node project)
SENTRY_DSN=https://...@o0.ingest.sentry.io/0
SENTRY_RELEASE=nombaos@1.0.0
SENTRY_TRACES_SAMPLE_RATE=0.2   # production: 0.0–1.0

# PostHog (https://app.posthog.com — same project as frontend, or a separate one)
POSTHOG_API_KEY=phc_...
POSTHOG_HOST=https://app.posthog.com
